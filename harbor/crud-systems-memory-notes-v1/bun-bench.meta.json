{
  "bun_bench_id": "crud-systems.memory-notes.v1",
  "task_version": "1.0.0",
  "spec_version": "0.1.0",
  "title": "In-memory notes CRUD API",
  "category": "crud-systems",
  "difficulty": {
    "level": 2,
    "rationale": "Requires multiple endpoints, mutable state, validation, and stable id generation.",
    "expected_code_size": {
      "min_lines": 60,
      "max_lines": 260
    },
    "expected_concepts": [
      "in-memory persistence",
      "CRUD routing",
      "JSON validation"
    ]
  },
  "tags": [
    "crud-systems",
    "bun",
    "json",
    "notes"
  ],
  "scoring": {
    "max_score": 100,
    "gates": [
      {
        "name": "installs",
        "requirement": "install exits with status 0",
        "on_fail": "zero"
      },
      {
        "name": "starts",
        "requirement": "readiness check passes",
        "on_fail": "zero"
      },
      {
        "name": "security_baseline",
        "requirement": "no hidden test access or network egress",
        "on_fail": "zero"
      }
    ],
    "weights": {
      "correctness": 0.8,
      "edge_cases": 0.1,
      "performance": 0.03,
      "security": 0.05,
      "maintainability": 0.02
    },
    "performance": {
      "metric": "p95_latency_ms",
      "budget": 50,
      "floor": 5
    },
    "dependency_budget": {
      "max_runtime_dependencies": 0,
      "penalty_per_extra_dependency": 1
    }
  },
  "success_criteria": {
    "must": [
      "POST /notes returns HTTP 201 with id and text.",
      "GET /notes returns notes in insertion order.",
      "Note ids increment from note_1."
    ],
    "must_not": [
      "Accept missing or blank text.",
      "Return plain text or HTML for API responses."
    ],
    "edge_cases": [
      "Blank text returns invalid_text.",
      "Multiple notes keep insertion order."
    ]
  },
  "environment_network": "disabled",
  "reward_model": {
    "description": "Harbor reward.txt is computed by the bun-bench gate model in tests/test.sh.",
    "values": {
      "public_and_hidden_pass": 1,
      "public_pass_hidden_fail": 0.25,
      "public_fail": 0
    },
    "maps_to_bun_bench_score": {
      "1.0": 100,
      "0.25": 25,
      "0.0": 0
    }
  }
}

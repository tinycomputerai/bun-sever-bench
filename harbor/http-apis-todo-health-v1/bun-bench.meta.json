{
  "bun_bench_id": "http-apis.todo-health.v1",
  "task_version": "1.0.0",
  "spec_version": "0.1.0",
  "title": "Todo service health endpoint",
  "category": "http-apis",
  "difficulty": {
    "level": 1,
    "rationale": "Requires one HTTP endpoint, JSON response handling, and a defined fallback for unsupported routes.",
    "expected_code_size": {
      "min_lines": 20,
      "max_lines": 120
    },
    "expected_concepts": [
      "Bun HTTP server",
      "JSON responses",
      "route matching"
    ]
  },
  "tags": [
    "http-apis",
    "bun",
    "json",
    "health-check"
  ],
  "scoring": {
    "max_score": 100,
    "gates": [
      {
        "name": "installs",
        "requirement": "install exits with status 0",
        "on_fail": "zero"
      },
      {
        "name": "starts",
        "requirement": "readiness check passes",
        "on_fail": "zero"
      },
      {
        "name": "security_baseline",
        "requirement": "no hidden test access or network egress",
        "on_fail": "zero"
      }
    ],
    "weights": {
      "correctness": 0.8,
      "edge_cases": 0.1,
      "performance": 0.03,
      "security": 0.05,
      "maintainability": 0.02
    },
    "performance": {
      "metric": "p95_latency_ms",
      "budget": 50,
      "floor": 5
    },
    "dependency_budget": {
      "max_runtime_dependencies": 0,
      "penalty_per_extra_dependency": 1
    }
  },
  "success_criteria": {
    "must": [
      "GET /health returns HTTP 200.",
      "GET /health returns the exact JSON body {\"ok\": true}.",
      "Every response body is JSON.",
      "The service listens on PORT."
    ],
    "must_not": [
      "Return extra fields from GET /health.",
      "Return plain text or HTML for API responses.",
      "Return HTTP 200 for unsupported routes or methods."
    ],
    "edge_cases": [
      "GET /health with query parameters still returns {\"ok\": true}.",
      "POST /health returns HTTP 404 with JSON."
    ]
  },
  "environment_network": "disabled",
  "reward_model": {
    "description": "Harbor reward.txt is computed by the bun-bench gate model in tests/test.sh.",
    "values": {
      "public_and_hidden_pass": 1,
      "public_pass_hidden_fail": 0.25,
      "public_fail": 0
    },
    "maps_to_bun_bench_score": {
      "1.0": 100,
      "0.25": 25,
      "0.0": 0
    }
  }
}
